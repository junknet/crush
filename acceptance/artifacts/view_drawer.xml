CrossingRewrites: int&#10;    hoistedColumns: int&#10;&#10;  HoistedCol = object&#10;    basePtr: SymId&#10;    column: int&#10;    symId: SymId&#10;    ty: TagId&#10;&#10;  HpcSemanticContext = object&#10;    localVectorSymbols: HashSet[SymId]&#10;    monotonicSymbols: HashSet[SymId]&#10;    insideLoop: bool&#10;    hoisted: seq[HoistedCol]&#10;    symCounter: int&#10;&#10;proc hasPragma(pragmas: Cursor, target: TagEnum): bool =&#10;  if pragmas.kind != ParLe or pragmas.tagEnum != PragmasTagId: return false&#10;  var item = pragmas.firstSon&#10;  while hasCurrentToken(item) and item.kind != ParRi:&#10;    if item.kind == ParLe:&#10;      if item.tagEnum == target: return true&#10;      skip item&#10;    else: inc item&#10;  return false&#10;&#10;proc collectHpcSymbols(c: var Cursor, ctx: var HpcSemanticContext, stats: var HpcSemanticStats) =&#10;  if c.kind == ParLe:&#10;    let tag = c.tagEnum&#10;    if tag in {VarTagId, LetTagId, CursorTagId}:&#10;      var decl = c.firstSon&#10;      if decl.kind in {Symbol, SymbolDef}:&#10;        let nameSym = decl.symId&#10;        skip decl; skip decl&#10;        let pragmas = decl&#10;        if hasPragma(pragmas, VectorTagId): ctx.localVectorSymbols.incl nameSym&#10;        if hasPragma(pragmas, HpcMonotonicTagId):&#10;          ctx.monotonicSymbols.incl nameSym&#10;          inc stats.hpcMonotonicPragmas&#10;    inc c&#10;    while hasCurrentToken(c) and c.kind != ParRi:&#10;      collectHpcSymbols(c, ctx, stats)&#10;    if c.kind == ParRi: inc c&#10;  else: inc c&#10;&#10;proc peelExpr(c: Cursor): Cursor =&#10;  result = c&#10;  if result.kind == ParLe and result.tagEnum == ExprTagId: result = result.firstSon&#10;&#10;proc rewriteHpc(c: var Cursor, stats: var HpcSemanticStats, ctx: var HpcSemanticContext, dest: var TokenBuf) =&#10;  if not hasCurrentToken(c) or c.kind == EofToken: return&#10;  &#10;  if c.kind != ParLe:&#10;    dest.add c.load; inc c; return&#10;&#10;  let tag = c.tagEnum&#10;&#10;  if tag == WhileTagId:&#10;    dest.add c.load; inc c&#10;    let old = ctx.insideLoop; ctx.insideLoop = true&#10;    while hasCurrentToken(c) and c.kind != ParRi: rewriteHpc(c, stats, ctx, dest)&#10;    ctx.insideLoop = old&#10;    if hasCurrentToken(c) and c.kind == ParRi: (dest.add c.load; inc c)&#10;    return&#10;&#10;  if tag == IfTagId and ctx.insideLoop:&#10;    var eb = c.firstSon&#10;    if eb.kind == ParLe and eb.tagEnum == ElifTagId:&#10;      let pc = peelExpr(eb.firstSon)&#10;      if pc.kind == ParLe and pc.tagEnum in {LtTagId, LeTagId, EqTagId, NeqTagId}:&#10;        var ts = pc.firstSon; var a1 = ts; if a1.hasMore: skip a1&#10;        var a2 = a1; if a2.hasMore: skip a2&#10;        if a2.hasMore:&#10;          let pa2 = peelExpr(a2)&#10;          if pa2.kind == Symbol and ctx.monotonicSymbols.contains(pa2.symId):&#10;            inc stats.monotonicCrossingRewrites&#10;            dest.addParLe TagId(IfTagId), c.info&#10;            var br = c.firstSon&#10;            while hasCurrentToken(br) and br.kind != ParRi:&#10;              if br.kind == ParLe and br.tagEnum == ElifTagId:&#10;                dest.addParLe TagId(ElifTagId), br.info&#10;                dest.addParLe TagId(CallTagId), br.info&#10;                dest.add symToken(pool.syms.getOrIncl("unlikely"), br.info)&#10;                dest.addSubtree br.firstSon; dest.addParRi br.info&#10;                var b = br.firstSon; skip b&#10;                while hasCurrentToken(b) and b.kind != ParRi: rewriteHpc(b, stats, ctx, dest)&#10;                dest.addParRi br.info; skip br&#10;              else: (var t = br; rewriteHpc(t, stats, ctx, dest); br = t)&#10;            dest.addParRi c.info; skip c; return&#10;&#10;  dest.addParLe c.tagId, c.info; inc c&#10;  while hasCurrentToken(c) and c.kind != ParRi: rewriteHpc(c, stats, ctx, dest)&#10;  if hasCurrentToken(c) and c.kind == ParRi: (dest.add c.load; inc c)&#10;&#10;proc main() =&#10;  if paramCount() != 2: quit "usage: hpc_semantic_lower &lt;in.s.nif&gt; &l