esc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[99,564][834,629]" /><node index="3" text="" resource-id="" class="android.widget.TextView" package="com.junknet.crushmobile" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[99,647][834,705]" /><node index="4" text="经过对 mobile/crush_mobile/app/index.tsx 的排查，发现以下三个严重的性能热点：" resource-id="" class="android.widget.TextView" package="com.junknet.crushmobile" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[99,729][834,924]" /><node index="5" text="" resource-id="" class="android.widget.TextView" package="com.junknet.crushmobile" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[99,948][834,1006]" /><node index="6" text="1." resource-id="" class="android.widget.TextView" package="com.junknet.crushmobile" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[123,1030][156,1095]" /><node index="7" text="渲染链路断裂（Reference Stability）：原有的 displayMessages 聚合逻辑在每次消息流更新时，都会为所有历史消息创建全新的对象引用。这导致 FlatList 中的 React.memo 全部失效，即使是几百条前的历史消息也会在每个 Token 到达时触发重绘。" resource-id="" class="android.widget.TextView" package="com.junknet.crushmobile" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[174,1030][834,1550]" /><node index="8" text="2." resource-id="" class="android.widget.TextView" package="com.junknet.crushmobile" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[123,1571][156,1636]" /><node index="9" text="JS 线程阻塞（Heavy Tokenization）：语法高亮逻辑 renderHighlightedCode 作为一个普通函数在渲染周期内被高频调用。对于长代码块，每次流式更新都会在 JS 线程重新执行复杂的正则表达式拆包，直接抢占了 UI 响应时间。" resource-id="" class="android.widget.TextView" package="com.junknet.crushmobile" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[174,1571][834,2091]" /><node index="10" text="3." resource-id="" class="android.widget.TextView" package="com.junknet.crushmobile" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[123,2112][156,2177]" /><node index="11" text="大组件重绘（Component Complexity）：MessageItem 及其子组件（Markdown、代码块、终端卡片）缺乏细粒度的 memo 保护，导致微小的状态变更引发了大面积的虚拟 DOM 树比对。" resource-id="" class="android.widget.TextView" package="com.junknet.crushmobile" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[174,2112][834,2209]" /></node></node></node><node index="7" text="" resource-id="" class="android.view.ViewGroup" package="com.junknet.crushmobile" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,2209][1080,2400]" /><node index="8" text="输入任务或指令..."