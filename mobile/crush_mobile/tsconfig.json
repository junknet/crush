{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@components/*": [
        "app/components/*"
      ],
      "@screens/*": [
        "app/screens/*"
      ],
      "@lib/*": [
        "lib/*"
      ],
      "@assets/*": [
        "assets/*"
      ],
      "@public/*": [
        "public/*"
      ],
      "@db": [
        "db/db"
      ]
    },
    "allowJs": true
  },
  "include": [
    "app/index.tsx",
    "app/_layout.tsx",
    "lib/crush/**/*.ts"
  ]
}
